{
  "name": "citevahti-vscode",
  "displayName": "CiteVahti (Vahtian)",
  "description": "Run citation-integrity tests on your manuscript claims, inline. Verify the claim before you cite it. A product of Vahtian.",
  "version": "0.21.5",
  "publisher": "heidihelena",
  "author": "Vahtian",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2D2440",
    "theme": "dark"
  },
  "keywords": [
    "zotero",
    "citation",
    "references",
    "academic writing",
    "research integrity",
    "citevahti"
  ],
  "homepage": "https://github.com/heidihelena/citevahti#readme",
  "bugs": {
    "url": "https://github.com/heidihelena/citevahti/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heidihelena/citevahti.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "activationEvents": [
    "onCommand:citevahti.startReview",
    "onCommand:citevahti.verifyClaims",
    "onCommand:citevahti.connectZotero"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "citevahti.startReview",
        "title": "CiteVahti: Start manuscript review"
      },
      {
        "command": "citevahti.verifyClaims",
        "title": "CiteVahti: Verify claims"
      },
      {
        "command": "citevahti.connectZotero",
        "title": "CiteVahti: Connect Zotero"
      },
      {
        "command": "citevahti.revertManuscriptEdit",
        "title": "CiteVahti: Revert manuscript edit (from backup)"
      }
    ],
    "configuration": {
      "title": "CiteVahti",
      "properties": {
        "citevahti.cliPath": {
          "type": "string",
          "default": "citevahti",
          "description": "Path to the CiteVahti CLI (install CiteVahti in a venv and point here; the legacy `citevahti` command also works)."
        },
        "citevahti.root": {
          "type": "string",
          "default": "",
          "description": "Project root containing .citevahti/ (defaults to the workspace folder)."
        },
        "citevahti.collectionKey": {
          "type": "string",
          "default": "",
          "description": "Zotero collection key to write verified references into (optional)."
        },
        "citevahti.library": {
          "type": "string",
          "default": "",
          "description": "Zotero write target: 'personal' or 'group:<id>'. Leave empty to use the library configured at onboarding."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/node": "^26",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0"
  }
}
