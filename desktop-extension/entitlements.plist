<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- PyInstaller --onefile extracts bundled .dylib/.so to a temp dir at runtime.
       Under the hardened runtime, library validation would reject those unsigned
       libs and the binary would crash. These entitlements are the standard
       onefile-notarization workaround. (A cleaner long-term fix is --onedir with
       every nested binary signed; see BUILD.md.) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
</dict>
</plist>
